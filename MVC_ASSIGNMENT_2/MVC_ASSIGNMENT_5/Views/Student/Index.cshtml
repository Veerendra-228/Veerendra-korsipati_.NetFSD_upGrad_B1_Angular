@model IEnumerable<MVC_ASSIGNMENT_5.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add New Student</a>

<table type="table"border="1">
    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>Email</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Age</td>
            <td>@item.Email</td>
            <td>
                <a href="/Student/Edit/@item.Id">Edit</a> |
                <a href="/Student/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>