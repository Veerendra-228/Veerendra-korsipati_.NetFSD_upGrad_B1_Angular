<!DOCTYPE html>
<html>
<head>
    <title>ViewBag vs ViewData</title>
</head>
<body>

    <h2>Student Info</h2>

    <!-- Using ViewBag -->
    <p><strong>Name (ViewBag):</strong> @ViewBag.StudentName</p>

    <!-- Using ViewData -->
    <p><strong>Age (ViewData):</strong> @ViewData["StudentAge"]</p>

</body>
</html>